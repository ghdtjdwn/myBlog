---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { withBase } from "../../lib/site";

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
  const projects = await getCollection("projects", ({ data }) => showDrafts || !data.draft);
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
const posts = await getCollection("posts", ({ data }) => (showDrafts || !data.draft) && data.project?.id === project.id);
---

<BaseLayout title={`${project.data.title} — 홍성주`} description={project.data.summary} image={project.data.image}>
  <article class="case-page">
    <header class="case-hero shell reading-shell">
      <div>
        <a class="back-link" href={withBase("projects/")}>← 프로젝트</a>
        <p class="case-status">{project.data.status} · {project.data.role}</p>
        <h1>{project.data.title}</h1>
        <p>{project.data.summary}</p>
        <div class="case-actions">
          {project.data.live && <a class="inline-link" href={project.data.live} target="_blank" rel="noreferrer">서비스 보기 ↗</a>}
          {project.data.repositories.map((repository) => <a class="inline-link" href={repository.url} target="_blank" rel="noreferrer">{repository.label} ↗</a>)}
        </div>
      </div>
      {project.data.image && <figure><Image src={project.data.image} alt={project.data.imageAlt ?? `${project.data.title} 프로젝트 화면`} widths={[640, 960, 1280]} sizes="(max-width: 900px) 100vw, 860px" /><figcaption>{project.data.imageAlt}</figcaption></figure>}
    </header>
    <section class="case-facts">
      <div class="shell reading-shell fact-grid">
        <div><span>ROLE</span><strong>{project.data.role}</strong></div>
        {project.data.metrics.slice(0, 3).map((metric) => <div><span>{metric.label}</span><strong>{metric.value}</strong></div>)}
      </div>
    </section>
    <div class="article-layout shell">
      <aside class="article-aside">
        <p>STACK & FOCUS</p>
        <div class="tag-row">{[...project.data.tags, ...project.data.infra].map((tag) => <span>{tag}</span>)}</div>
      </aside>
      <div class="prose"><Content /></div>
    </div>
  </article>
  {posts.length > 0 && (
    <section class="related-section">
      <div class="shell reading-shell">
        <header class="list-heading"><h2>이 프로젝트의 글</h2></header>
        <div class="post-list">{posts.map((post) => <PostCard post={post} />)}</div>
      </div>
    </section>
  )}
</BaseLayout>
