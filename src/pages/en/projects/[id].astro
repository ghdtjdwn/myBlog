---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/PostCard.astro";
import ProjectGallery from "../../../components/ProjectGallery.astro";
import { projectActivityLabelsEn, projectStatusLabelsEn, projectVisibilityLabelsEn } from "../../../lib/i18n";
import { withBase } from "../../../lib/site";
export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
  const projects = await getCollection("projectsEn", ({ data }) => showDrafts || !data.draft);
  return projects.map((project) => ({ params: { id: project.id }, props: { project } }));
}
const { project } = Astro.props;
const { Content } = await render(project);
const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
const posts = (await getCollection("postsEn", ({ data }) => (showDrafts || !data.draft) && data.project?.id === project.id))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---
<BaseLayout locale="en" title={`${project.data.title} — Hong Seong Ju`} description={project.data.summary} image={project.data.image}>
  <article class="case-page">
    <header class="case-hero shell reading-shell"><div><a class="back-link" href={withBase("en/projects/")}>← Projects</a><p class="case-status">{projectStatusLabelsEn[project.data.status]} · {projectActivityLabelsEn[project.data.activity]}</p><h1>{project.data.title}</h1><p>{project.data.summary}</p><p class="project-status-note"><strong>Current status</strong> {project.data.statusNote}</p><div class="case-actions">{project.data.live && <a class="inline-link" href={project.data.live} target="_blank" rel="noreferrer">Live service ↗</a>}{project.data.repositories.map((repository) => <a class="inline-link" href={repository.url} target="_blank" rel="noreferrer">{repository.label} ↗</a>)}</div></div>
      {project.data.image && <figure><Image src={project.data.image} alt={project.data.imageAlt ?? `${project.data.title} project screen`} widths={[640, 960, 1280]} sizes="(max-width: 900px) 100vw, 860px" /><figcaption>{project.data.imageAlt}</figcaption></figure>}
    </header>
    <section class="case-facts"><div class="shell reading-shell fact-grid"><div><span>ROLE</span><strong>{project.data.role}</strong></div><div><span>ACTIVITY</span><strong>{projectActivityLabelsEn[project.data.activity]}</strong></div>{project.data.metrics.slice(0, 2).map((metric) => <div><span>{metric.label}</span><strong>{metric.value}</strong></div>)}</div></section>
    <section class="claim-section"><div class="shell reading-shell"><header class="claim-heading"><p class="intro-label">Verified scope</p><h2>Contribution boundaries and evidence</h2></header><dl class="claim-list">
      <div><dt>Direct role</dt><dd>{project.data.role}</dd></div>
      {project.data.teamScope && <div><dt>Team boundary</dt><dd>{project.data.teamScope}</dd></div>}
      <div><dt>Evidence visibility</dt><dd>{projectVisibilityLabelsEn[project.data.visibility]}</dd></div>
      {project.data.contributionEvidence.length > 0 && <div><dt>Contribution evidence</dt><dd><ul>{project.data.contributionEvidence.map((evidence) => <li>{evidence}</li>)}</ul></dd></div>}
    </dl></div></section>
    <ProjectGallery
      screenshots={project.data.architecture}
      id="project-architecture"
      eyebrow="System architecture"
      title="Service architecture"
      intro="These repository-source diagrams show the service boundaries and operating flows. Select an image to open it at full size."
      layout="wide"
      openLabel="Open full-size image"
    />
    <ProjectGallery
      screenshots={project.data.screenshots}
      id="project-screens"
      eyebrow="Product screens"
      title="Key operating screens"
      intro="These screens show the service's primary features and operating state. Select an image to open it at full size."
      openLabel="Open full-size image"
    />
    <div class="article-layout shell"><aside class="article-aside"><p>STACK & FOCUS</p><div class="tag-row">{[...project.data.tags, ...project.data.infra].map((tag) => <span>{tag}</span>)}</div></aside><div class="prose"><Content /></div></div>
  </article>
  <section class="record-section"><div class="shell reading-shell"><header class="record-heading"><p class="intro-label">Engineering records</p><h2>Work logs and troubleshooting</h2><p>{project.data.recordPlan}</p></header>{project.data.recordLinks.length ? <div class="record-links">{project.data.recordLinks.map((record) => <a href={record.url} target="_blank" rel="noreferrer"><span>{record.label}</span><span>GitHub ↗</span></a>)}</div> : <p class="empty-state">Public source links are still being prepared. Private and team records will be linked only after their publication scope is confirmed.</p>}</div></section>
  {posts.length > 0 && <section class="related-section"><div class="shell reading-shell"><header class="list-heading"><h2>Writing about this project</h2></header><div class="post-list">{posts.map((post) => <PostCard post={post} locale="en" />)}</div></div></section>}
</BaseLayout>
