---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site, withBase } from "../lib/site";

const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
const projects = (await getCollection("projects", ({ data }) => showDrafts || !data.draft)).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const posts = (await getCollection("posts", ({ data }) => showDrafts || !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout>
  <div class="shell reading-shell home">
    <section class="home-intro">
      <p class="intro-label">안녕하세요, 개발자 홍성주입니다.</p>
      <h1>만들며 배운 것을 기록합니다.</h1>
      <p>
        백엔드와 데이터, AI 시스템을 만들고 운영합니다. 성공한 결과만 정리하기보다
        막혔던 지점, 선택한 이유, 실제로 확인한 증거를 글로 남깁니다.
      </p>
      <div class="inline-links">
        <a href={withBase("about/")}>더 알아보기</a>
        <a href={site.github} target="_blank" rel="noreferrer">GitHub ↗</a>
      </div>
    </section>

    <section class="home-section">
      <header class="list-heading"><h2>최근 글</h2><a href={withBase("writing/")}>전체 보기</a></header>
      {posts.length > 0 ? <div class="post-list">{posts.slice(0, 5).map((post) => <PostCard post={post} />)}</div> : <p class="empty-state">첫 글을 공개하기 전에 근거와 표현을 확인하고 있습니다.</p>}
    </section>

    <section class="home-section">
      <header class="list-heading"><h2>대표 프로젝트</h2><a href={withBase("projects/")}>전체 보기</a></header>
      <div class="project-list">{featuredProjects.slice(0, 3).map((project) => <ProjectCard project={project} />)}</div>
    </section>
  </div>
</BaseLayout>
