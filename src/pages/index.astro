---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { withBase } from "../lib/site";
import { getSiteSettings } from "../lib/settings";

const settings = await getSiteSettings();
const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
const projects = (await getCollection("projects", ({ data }) => showDrafts || !data.draft)).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const posts = (await getCollection("posts", ({ data }) => showDrafts || !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout>
  <div class="shell reading-shell home">
    <section class="home-intro">
      <p class="intro-label">{settings.home.introLabelKo}</p>
      <h1>{settings.home.headingKo}</h1>
      <p>{settings.home.summaryKo}</p>
      <div class="inline-links">
        <a href={withBase("about/")}>더 알아보기</a>
        <a href={settings.contact.github} target="_blank" rel="noreferrer">GitHub ↗</a>
      </div>
    </section>

    <section class="home-section">
      <header class="list-heading"><h2>{settings.home.recentPostsLabelKo}</h2><a href={withBase("writing/")}>전체 보기</a></header>
      {posts.length > 0 ? <div class="post-list">{posts.slice(0, settings.home.recentPostCount).map((post) => <PostCard post={post} />)}</div> : <p class="empty-state">첫 글을 공개하기 전에 근거와 표현을 확인하고 있습니다.</p>}
    </section>

    <section class="home-section">
      <header class="list-heading"><h2>{settings.home.featuredProjectsLabelKo}</h2><a href={withBase("projects/")}>전체 보기</a></header>
      <div class="project-list">{featuredProjects.slice(0, settings.home.featuredProjectCount).map((project) => <ProjectCard project={project} />)}</div>
    </section>
  </div>
</BaseLayout>
