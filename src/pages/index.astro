---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { site, withBase } from "../lib/site";

const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
const projects = (await getCollection("projects", ({ data }) => showDrafts || !data.draft)).sort((a, b) => a.data.order - b.data.order);
const featuredProjects = projects.filter((project) => project.data.featured);
const posts = (await getCollection("posts", ({ data }) => showDrafts || !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout>
  <section class="hero shell">
    <div class="hero-copy">
      <p class="eyebrow"><span></span> Backend · Data · AI Systems</p>
      <h1>작동하는 시스템을 만들고,<br /><em>판단의 근거</em>를 남깁니다.</h1>
      <p class="hero-lead">
        실제 운영 환경까지 연결한 제품을 만들며 성능, 장애, 보안, 아키텍처 의사결정을
        재현 가능한 증거로 기록하는 개발자 홍성주입니다.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase("projects/")}>프로젝트 보기</a>
        <a class="button secondary" href={withBase("writing/")}>기술 글 읽기</a>
      </div>
    </div>
    <aside class="hero-ledger" aria-label="대표 작업 지표">
      <p class="ledger-label">CURRENT FOCUS / 2026</p>
      <div class="ledger-row"><strong>1,200+</strong><span>automated tests<br />across campus AI</span></div>
      <div class="ledger-row"><strong>150k+</strong><span>public places<br />served with PostGIS</span></div>
      <div class="ledger-row"><strong>84</strong><span>architecture<br />decision records</span></div>
      <div class="ledger-status"><i></i><span>Building in public through evidence</span></div>
    </aside>
  </section>

  <section class="principles-band">
    <div class="shell principle-grid">
      <p>제품을 배포에서 끝내지 않고 운영 가능한 상태까지 연결합니다.</p>
      <ol>
        <li><span>01</span>Measure before tuning</li>
        <li><span>02</span>Fail closed at trust boundaries</li>
        <li><span>03</span>Document meaningful trade-offs</li>
      </ol>
    </div>
  </section>

  <section class="section shell">
    <header class="section-header">
      <div><p class="eyebrow"><span></span> Selected work</p><h2>대표 프로젝트</h2></div>
      <a class="text-link" href={withBase("projects/")}>모든 프로젝트 <span>→</span></a>
    </header>
    <div class="project-grid">
      {featuredProjects.map((project, index) => <ProjectCard project={project} wide={index === 0} />)}
    </div>
  </section>

  <section class="section section-ink">
    <div class="shell">
      <header class="section-header inverse">
        <div><p class="eyebrow"><span></span> Engineering notes</p><h2>최근 기술 글</h2></div>
        <a class="text-link" href={withBase("writing/")}>모든 글 <span>→</span></a>
      </header>
      {posts.length > 0 ? <div class="post-grid">{posts.slice(0, 3).map((post) => <PostCard post={post} />)}</div> : <p class="empty-state">첫 기술 기록을 검증하고 있습니다.</p>}
    </div>
  </section>

  <section class="cta shell">
    <div>
      <p class="eyebrow"><span></span> Work with me</p>
      <h2>코드보다 먼저 문제를 보고,<br />말보다 먼저 증거를 만듭니다.</h2>
    </div>
    <div>
      <p>프로젝트, 공모전, 연합 활동에서 제품 구현과 기술적 의사결정이 필요한 팀을 찾고 있습니다.</p>
      <a class="button primary" href={site.github} target="_blank" rel="noreferrer">GitHub에서 작업 보기 ↗</a>
    </div>
  </section>
</BaseLayout>
