---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, withBase } from "../../lib/site";

export async function getStaticPaths() {
  const showDrafts = import.meta.env.DEV || import.meta.env.SHOW_DRAFTS === "true";
  const posts = await getCollection("posts", ({ data }) => showDrafts || !data.draft);
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const category = await getEntry(post.data.category);
const activity = post.data.activity ? await getEntry(post.data.activity) : undefined;
const project = post.data.project ? await getEntry(post.data.project) : undefined;
---

<BaseLayout
  title={`${post.data.title} — 홍성주`}
  description={post.data.description}
  type="article"
  publishedAt={post.data.publishedAt}
  updatedAt={post.data.updatedAt}
>
  <article>
    <header class="article-hero shell reading-shell">
      <a class="back-link" href={withBase("writing/")}>← 기술 글</a>
      <div class="post-meta">
        <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
        {post.data.updatedAt && <span>수정 {formatDate(post.data.updatedAt)}</span>}
      </div>
      <div class="article-categories">
        {category && <a href={withBase(`writing/category/${category.id}/`)}>{category.data.name}</a>}
        {activity && <a href={withBase(`writing/category/${activity.id}/`)}>{activity.data.name}</a>}
      </div>
      <h1>{post.data.title}</h1>
      <p>{post.data.description}</p>
      <div class="tag-row">{post.data.tags.map((tag) => <span>{tag}</span>)}</div>
    </header>
    <div class="article-layout shell article-body">
      <aside class="article-aside toc">
        <p>IN THIS NOTE</p>
        <ol>{headings.filter((heading) => heading.depth === 2).map((heading) => <li><a href={`#${heading.slug}`}>{heading.text}</a></li>)}</ol>
      </aside>
      <div class="prose"><Content /></div>
    </div>
    <section class="claim-section article-claims">
      <div class="shell reading-shell">
        <header class="claim-heading">
          <p class="intro-label">Evidence note</p>
          <h2>이 글의 역할, 검증과 한계</h2>
        </header>
        <dl class="claim-list">
          <div><dt>직접 역할</dt><dd>{post.data.role}</dd></div>
          {project && <div><dt>연결 프로젝트</dt><dd><a href={withBase(`projects/${project.id}/`)}>{project.data.title} →</a></dd></div>}
          <div><dt>근거</dt><dd><ul>{post.data.evidence.map((item) => <li>{item}</li>)}</ul></dd></div>
          <div><dt>검증</dt><dd><ul>{post.data.validation.map((item) => <li>{item}</li>)}</ul></dd></div>
          <div><dt>일반화하지 않는 범위</dt><dd><ul>{post.data.limitations.map((item) => <li>{item}</li>)}</ul></dd></div>
        </dl>
      </div>
    </section>
  </article>
</BaseLayout>
