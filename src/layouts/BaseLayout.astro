---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { site, withBase } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string } | string;
  type?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
}

const {
  title = site.title,
  description = site.description,
  image,
  type = "website",
  publishedAt,
  updatedAt,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const isPreview = process.env.VERCEL_ENV === "preview";
const pathname = Astro.url.pathname;
const imagePath = (typeof image === "string" ? image : image?.src) ?? "og-blog.png";
const resolvedImagePath = imagePath.startsWith(import.meta.env.BASE_URL) ? imagePath : withBase(imagePath);
const imageUrl = new URL(resolvedImagePath, Astro.site);
const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        datePublished: publishedAt?.toISOString(),
        dateModified: (updatedAt ?? publishedAt)?.toISOString(),
        mainEntityOfPage: canonical.toString(),
        author: {
          "@type": "Person",
          name: site.name,
          url: new URL(withBase("about/"), Astro.site).toString(),
          sameAs: [site.github],
        },
      }
    : {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        mainEntity: {
          "@type": "Person",
          name: site.name,
          url: canonical.toString(),
          sameAs: [site.github],
        },
      };
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f4f0e8" />
    {isPreview && <meta name="robots" content="noindex, nofollow" />}
    <Analytics />
    <SpeedInsights />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={site.title} href={withBase("rss.xml")} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#content">본문으로 바로가기</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={withBase("")} aria-label="홍성주 홈">
          <strong>홍성주</strong><span>개발 노트</span>
        </a>
        <nav aria-label="주요 메뉴">
          <a href={withBase("writing/")} aria-current={pathname.includes("/writing") ? "page" : undefined}>글</a>
          <a href={withBase("projects/")} aria-current={pathname.includes("/projects") ? "page" : undefined}>프로젝트</a>
          <a href={withBase("about/")} aria-current={pathname.includes("/about") ? "page" : undefined}>소개</a>
          <a href={site.github} target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p>백엔드, 데이터, AI 시스템을 만들며 배운 것을 씁니다.</p>
        <p class="footer-meta">© {new Date().getFullYear()} 홍성주</p>
      </div>
      <div class="footer-links">
        <a href={withBase("rss.xml")}>RSS</a>
        <a href={site.github} target="_blank" rel="noreferrer">GitHub</a>
      </div>
    </footer>
  </body>
</html>
