---
import "../styles/global.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { withBase } from "../lib/site";
import { getSiteSettings, isExternalHref, managedHref } from "../lib/settings";

interface Props {
  title?: string;
  description?: string;
  image?: { src: string } | string;
  type?: "website" | "article";
  publishedAt?: Date;
  updatedAt?: Date;
  locale?: "ko" | "en";
}

const settings = await getSiteSettings();
const { locale = "ko" } = Astro.props;
const {
  title = locale === "ko" ? settings.siteTitleKo : settings.siteTitleEn,
  description = locale === "ko" ? settings.siteDescriptionKo : settings.siteDescriptionEn,
  image,
  type = "website",
  publishedAt,
  updatedAt,
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const isPreview = process.env.VERCEL_ENV === "preview";
const pathname = Astro.url.pathname;
const relativePath = pathname.startsWith(import.meta.env.BASE_URL)
  ? pathname.slice(import.meta.env.BASE_URL.length)
  : pathname.replace(/^\//, "");
const koPath = locale === "en" ? relativePath.replace(/^en\/?/, "") : relativePath;
const enPath = locale === "en" ? relativePath : `en/${relativePath}`;
const koUrl = new URL(withBase(koPath), Astro.site);
const enUrl = new URL(withBase(enPath), Astro.site);
const languageHref = locale === "ko" ? withBase(enPath) : withBase(koPath);
const verification = {
  google: import.meta.env.GOOGLE_SITE_VERIFICATION,
  naver: import.meta.env.NAVER_SITE_VERIFICATION,
};
const imagePath = (typeof image === "string" ? image : image?.src) ?? "og-blog.png";
const resolvedImagePath = imagePath.startsWith(import.meta.env.BASE_URL) ? imagePath : withBase(imagePath);
const imageUrl = new URL(resolvedImagePath, Astro.site);
const person = {
  "@type": "Person",
  name: locale === "ko" ? settings.authorNameKo : settings.authorNameEn,
  url: new URL(withBase(locale === "ko" ? "about/" : "en/about/"), Astro.site).toString(),
  email: `mailto:${settings.contact.email}`,
  affiliation: {
    "@type": "EducationalOrganization",
    name: "Soongsil University",
  },
  sameAs: [settings.contact.github, settings.contact.solvedAc].filter(Boolean),
  hasCredential: [
    {
      "@type": "EducationalOccupationalCredential",
      name: "컴퓨터활용능력 2급 (Computer Specialist in Spreadsheet & Database, Level II)",
      credentialCategory: "certificate",
    },
    {
      "@type": "EducationalOccupationalCredential",
      name: "정보처리기능사 (Craftsman Information Processing)",
      credentialCategory: "certificate",
    },
  ],
};
const headerNavigation = settings.navigation.filter((item) => item.showInHeader);
const footerNavigation = settings.navigation.filter((item) => item.showInFooter);
const themeColor = settings.appearance.theme === "night" ? "#17181b" : settings.appearance.theme === "warm" ? "#f4f0e8" : "#fafafa";
const localizedHref = (item: (typeof settings.navigation)[number]) => locale === "ko" ? item.hrefKo : item.hrefEn;
const localizedLabel = (item: (typeof settings.navigation)[number]) => locale === "ko" ? item.labelKo : item.labelEn;
const isCurrentNavigation = (href: string) => {
  if (isExternalHref(href)) return false;
  const target = new URL(managedHref(href), Astro.site).pathname.replace(/\/$/, "");
  const current = pathname.replace(/\/$/, "");
  return current === target || (target !== import.meta.env.BASE_URL.replace(/\/$/, "") && current.startsWith(`${target}/`));
};
const isProfilePage = /^\/?(?:en\/)?about\/?$/.test(relativePath);
const jsonLd =
  type === "article"
    ? {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: title,
        description,
        datePublished: publishedAt?.toISOString(),
        dateModified: (updatedAt ?? publishedAt)?.toISOString(),
        mainEntityOfPage: canonical.toString(),
        author: person,
      }
    : isProfilePage
      ? {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        mainEntity: person,
      }
      : {
          "@context": "https://schema.org",
          "@type": "WebPage",
          name: title,
          description,
          url: canonical.toString(),
          author: person,
        };
---

<!doctype html>
<html lang={locale} data-theme={settings.appearance.theme} data-accent={settings.appearance.accent}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    {verification.google && <meta name="google-site-verification" content={verification.google} />}
    {verification.naver && <meta name="naver-site-verification" content={verification.naver} />}
    {isPreview && <meta name="robots" content="noindex, nofollow" />}
    <Analytics />
    <SpeedInsights />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ko" href={koUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={koUrl} />
    <link rel="alternate" type="application/rss+xml" title={settings.siteTitleKo} href={withBase("rss.xml")} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#content">{locale === "ko" ? "본문으로 바로가기" : "Skip to content"}</a>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href={withBase(locale === "ko" ? "" : "en/")} aria-label={`${locale === "ko" ? settings.authorNameKo : settings.authorNameEn} home`}>
          <strong>{locale === "ko" ? settings.authorNameKo : settings.authorNameEn}</strong><span>{locale === "ko" ? settings.brandSubtitleKo : settings.brandSubtitleEn}</span>
        </a>
        <nav aria-label={locale === "ko" ? "주요 메뉴" : "Main navigation"}>
          {headerNavigation.map((item) => {
            const href = localizedHref(item);
            return <a href={managedHref(href)} target={item.newTab ? "_blank" : undefined} rel={item.newTab ? "noreferrer" : undefined} aria-current={isCurrentNavigation(href) ? "page" : undefined} data-external={isExternalHref(href) ? "" : undefined}>{localizedLabel(item)}</a>;
          })}
          <a class="language-link" href={languageHref} hreflang={locale === "ko" ? "en" : "ko"}>{locale === "ko" ? "EN" : "KO"}</a>
        </nav>
      </div>
    </header>
    <main id="content">
      <slot />
    </main>
    <footer class="site-footer">
      <div>
        <p>{locale === "ko" ? settings.footerTextKo : settings.footerTextEn}</p>
        <p class="footer-meta">© {new Date().getFullYear()} {locale === "ko" ? settings.authorNameKo : settings.authorNameEn}</p>
      </div>
      <div class="footer-links">
        <a href={withBase(locale === "ko" ? "rss.xml" : "en/rss.xml")}>RSS</a>
        {footerNavigation.map((item) => {
          const href = localizedHref(item);
          return <a href={managedHref(href)} target={item.newTab ? "_blank" : undefined} rel={item.newTab ? "noreferrer" : undefined}>{localizedLabel(item)}</a>;
        })}
      </div>
    </footer>
  </body>
</html>
