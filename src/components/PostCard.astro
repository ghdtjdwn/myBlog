---
import { getEntry, type CollectionEntry } from "astro:content";
import { formatDate, withBase } from "../lib/site";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const category = await getEntry(post.data.category);
const activity = post.data.activity ? await getEntry(post.data.activity) : undefined;
---

<article class="post-row">
  <time datetime={post.data.publishedAt.toISOString()}>{formatDate(post.data.publishedAt)}</time>
  <div>
    <h3><a href={withBase(`writing/${post.id}/`)}>{post.data.title}</a></h3>
    <p>{post.data.description}</p>
    <div class="post-taxonomy">
      {category && <a class="category-link" href={withBase(`writing/category/${category.id}/`)}>{category.data.name}</a>}
      {activity && <a class="activity-link" href={withBase(`writing/category/${activity.id}/`)}>{activity.data.name}</a>}
      <div class="tag-row" aria-label="글 태그">{post.data.tags.slice(0, 3).map((tag) => <span>{tag}</span>)}</div>
    </div>
  </div>
  <a class="row-arrow" href={withBase(`writing/${post.id}/`)} aria-label={`${post.data.title} 읽기`}>↗</a>
</article>
