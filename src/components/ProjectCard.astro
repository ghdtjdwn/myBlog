---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import { withBase } from "../lib/site";

interface Props {
  project: CollectionEntry<"projects">;
  wide?: boolean;
}

const { project, wide = false } = Astro.props;
const { data } = project;
---

<article class:list={["project-card", { wide }]}>
  <a class="project-image" href={withBase(`projects/${project.id}/`)} aria-label={`${data.title} 자세히 보기`}>
    {data.image ? (
      <Image src={data.image} alt={data.imageAlt ?? `${data.title} 프로젝트 화면`} widths={[480, 800, 1200]} sizes={wide ? "(max-width: 900px) 100vw, 60vw" : "(max-width: 680px) 100vw, 50vw"} loading="lazy" />
    ) : (
      <span class="project-placeholder" aria-hidden="true"><small>PROJECT / {String(data.order).padStart(2, "0")}</small><strong>{data.title}</strong></span>
    )}
    <span class="project-status">{data.status}</span>
  </a>
  <div class="project-content">
    <div class="tag-row" aria-label="기술 태그">
      {data.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}
    </div>
    <h3><a href={withBase(`projects/${project.id}/`)}>{data.title}</a></h3>
    <p>{data.summary}</p>
    <dl class="metric-row">
      {data.metrics.slice(0, 3).map((metric) => (
        <div><dt>{metric.label}</dt><dd>{metric.value}</dd></div>
      ))}
    </dl>
    <a class="text-link" href={withBase(`projects/${project.id}/`)}>Case study <span>→</span></a>
  </div>
</article>
