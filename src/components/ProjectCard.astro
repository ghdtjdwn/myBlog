---
import type { CollectionEntry } from "astro:content";
import { projectActivityLabels, projectStatusLabels, withBase } from "../lib/site";
import { projectActivityLabelsEn, projectStatusLabelsEn } from "../lib/i18n";

interface Props {
  project: CollectionEntry<"projects"> | CollectionEntry<"projectsEn">;
  locale?: "ko" | "en";
}

const { project, locale = "ko" } = Astro.props;
const { data } = project;
const prefix = locale === "en" ? "en/" : "";
const statusLabels = locale === "en" ? projectStatusLabelsEn : projectStatusLabels;
const activityLabels = locale === "en" ? projectActivityLabelsEn : projectActivityLabels;
---

<article class="project-row">
  <div class="project-index">{String(data.order).padStart(2, "0")}</div>
  <div class="project-main">
    <div class="project-title-line">
      <h3><a href={withBase(`${prefix}projects/${project.id}/`)}>{data.title}</a></h3>
      <span class:list={["status-dot", `status-${data.status}`]}>{statusLabels[data.status]}</span>
    </div>
    <p>{data.summary}</p>
    <p class="project-role">{activityLabels[data.activity]} · {data.role}</p>
    <div class="tag-row" aria-label="기술 태그">{data.tags.slice(0, 4).map((tag) => <span>{tag}</span>)}</div>
  </div>
  <a class="row-arrow" href={withBase(`${prefix}projects/${project.id}/`)} aria-label={`${data.title} ${locale === "ko" ? "자세히 보기" : "details"}`}>↗</a>
</article>
